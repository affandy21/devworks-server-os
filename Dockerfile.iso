FROM debian:bookworm

RUN apt-get update && apt-get install -y \
    live-build \
    ca-certificates \
    rsync \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY . /workspace/

RUN chmod +x /workspace/scripts/build-iso.sh \
    && chmod +x /workspace/iso/auto/config \
    && find /workspace/iso/config/hooks/normal -maxdepth 1 -type f -name '*.chroot' -exec chmod +x {} +

CMD ["/bin/bash", "-c", "cd /workspace && bash scripts/build-iso.sh"]
