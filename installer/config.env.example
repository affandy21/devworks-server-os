# Devworks Server OS installer configuration.
# Copy this file to config.env and edit it before running:
#   sudo bash installer/devworks-install.sh --config installer/config.env

# Safety gate. Disk installation is destructive.
# Interactive installs should keep DEVWORKS_MANUAL_CONFIRM_DISK="yes".
# Fully automated installs must set DEVWORKS_I_UNDERSTAND_THIS_ERASES_DISK="yes".
DEVWORKS_I_UNDERSTAND_THIS_ERASES_DISK="no"
DEVWORKS_MANUAL_CONFIRM_DISK="yes"
DEVWORKS_ALLOW_INSTALL_ON_MOUNTED_DISK="no"

# Target disk. Examples:
#   /dev/sda     VirtualBox SATA
#   /dev/vda     KVM virtio
#   /dev/nvme0n1 NVMe bare metal
INSTALL_MODE="erase-disk"        # erase-disk only; dualboot is a future non-destructive mode
TARGET_DISK="auto"               # auto shows an interactive disk picker
TARGET_BOOT_MODE="auto"          # auto, efi, bios
TARGET_ROOT_FS="ext4"            # ext4 only in this installer
TARGET_SWAP_SIZE_MIB="2048"      # 0 disables swap partition
TARGET_EFI_SIZE_MIB="512"
TARGET_ROOT_LABEL="DEVWORKS_ROOT"
TARGET_EFI_LABEL="DWORKS_EFI"
TARGET_SWAP_LABEL="DWORKS_SWAP"

# Base operating system.
DEVWORKS_HOSTNAME="devworks-server"
DEVWORKS_PRETTY_NAME="Devworks Server OS"
DEBIAN_RELEASE="bookworm"
DEBIAN_MIRROR="http://deb.debian.org/debian"
DEBIAN_SECURITY_MIRROR="http://security.debian.org/debian-security"
APT_COMPONENTS="main contrib non-free-firmware"
TIMEZONE="Asia/Jakarta"
LOCALE="en_US.UTF-8"
KEYMAP="us"

# Admin account.
ADMIN_USER="devworks"
ADMIN_FULL_NAME="Devworks Administrator"
ADMIN_PASSWORD_MODE="prompt"     # prompt, hash, locked
ADMIN_PASSWORD_HASH=""           # only used when ADMIN_PASSWORD_MODE=hash
FORCE_PASSWORD_CHANGE="no"       # prompt mode already collects the final password
ADMIN_SUDO_NOPASSWD="no"         # yes only for disposable lab builds
ENABLE_AUTOLOGIN="yes"           # recommended yes only for GUI/VirtualBox preview
AUTOLOGIN_USER="${ADMIN_USER}"

# SSH.
SSH_PORT="22"
SSH_PASSWORD_AUTH="yes"          # set no after SSH keys are deployed
SSH_PERMIT_ROOT_LOGIN="no"
SSH_ALLOW_USERS="${ADMIN_USER}"
SSH_AUTHORIZED_KEYS_FILE=""      # optional path copied into admin account
SSH_KEY_SETUP_MODE="prompt"      # prompt, required, skip
REQUIRE_SSH_AUTHORIZED_KEYS="no" # production profile sets yes
SSH_DISABLE_EMPTY_PASSWORDS="yes"
SSH_MAX_AUTH_TRIES="3"

# Firewall and TLS.
ENABLE_UFW="yes"
ALLOW_HTTP="no"                 # public ports are opened only after user opt-in
ALLOW_HTTPS="no"
ALLOW_ADMIN_UI_PORT="no"
ADMIN_UI_PORT="8088"
TLS_MODE="off"                   # self-signed, existing, certbot, off
TLS_DOMAIN="devworks.local"
TLS_CERT_SOURCE=""
TLS_KEY_SOURCE=""
CERTBOT_EMAIL="admin@example.com"

# Runtime and services. Defaults are feature-available, workload-disabled.
ENABLE_WEB_STACK="no"
WEB_SERVICE_NAME="devworks-web"
WEB_SERVICE_PORT="80"
WEB_ROOT="/srv/devworks/web"
WEB_ENABLE_FIREWALL="no"
WEB_TLS_MODE="off"
ENABLE_AI_RUNTIME="no"
AI_SERVICE_NAME="devworks-ai"
AI_RUNTIME_MODE="ollama"         # ollama, placeholder, none
AI_SERVICE_PORT="11434"
AI_BIND_ADDRESS="127.0.0.1"
AI_MEMORY_MAX="8G"
AI_CPU_QUOTA="300%"
AI_ENABLE_FIREWALL="no"
ENABLE_CONTAINER_RUNTIME="none"  # podman, docker, none
INSTALL_WEB_FEATURE_PACKAGES="yes"
INSTALL_AI_FEATURE_PACKAGES="no"
INSTALL_CONTAINER_FEATURE_PACKAGES="no"
ENABLE_SERVICE_WIZARD="yes"

# GUI and monitoring.
ENABLE_GUI="yes"
ENABLE_NATIVE_MONITOR="yes"
ENABLE_ADMIN_WEB_UI="no"         # native monitor is default; browser UI is opt-in
ADMIN_WEB_UI_BIND="127.0.0.1"    # production should stay local-only
WALLPAPER_SOURCE="/usr/share/backgrounds/halo/devworks-wallpaper.png"

# Updates and recovery.
ENABLE_UNATTENDED_UPGRADES="yes"
ENABLE_AUTO_REBOOT_AFTER_SECURITY_UPDATE="no"
GRUB_TIMEOUT="5"
GRUB_CMDLINE_LINUX_DEFAULT="quiet"
ENABLE_GRUB_RECOVERY="yes"

# Validation.
VALIDATE_RETRY_COUNT="30"
VALIDATE_RETRY_SLEEP="2"
POST_INSTALL_REBOOT="no"
