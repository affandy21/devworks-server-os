# Destructive VirtualBox autoinstall profile.
# This profile is intended only for an empty VirtualBox VM disk.
DEVWORKS_I_UNDERSTAND_THIS_ERASES_DISK="yes"
DEVWORKS_MANUAL_CONFIRM_DISK="no"
DEVWORKS_ALLOW_INSTALL_ON_MOUNTED_DISK="no"
INSTALL_MODE="erase-disk"
TARGET_DISK="/dev/sda"
TARGET_BOOT_MODE="bios"
TARGET_EFI_LABEL="DWORKS_EFI"
TARGET_SWAP_LABEL="DWORKS_SWAP"
TARGET_SWAP_SIZE_MIB="2048"
DEVWORKS_HOSTNAME="devworks-server"
ADMIN_USER="devworks"
ADMIN_FULL_NAME="Devworks Administrator"
ADMIN_PASSWORD_MODE="hash"
ADMIN_PASSWORD_HASH='$6$devworks$r5qVp8MHvcW5CJD7zAf.h8.2tUSSGbb.LMygheKIvkKaXytQ27g0yZsc2Z/KD/TJQNjnQIA.EvDcni1vljESs/'
ADMIN_SUDO_NOPASSWD="yes"
ENABLE_AUTOLOGIN="yes"
SSH_PASSWORD_AUTH="yes"
SSH_KEY_SETUP_MODE="skip"
ENABLE_GUI="yes"
ENABLE_NATIVE_MONITOR="yes"
ENABLE_ADMIN_WEB_UI="no"
ALLOW_ADMIN_UI_PORT="no"
ENABLE_CONTAINER_RUNTIME="none"
INSTALL_WEB_FEATURE_PACKAGES="yes"
INSTALL_CONTAINER_FEATURE_PACKAGES="no"
ENABLE_WEB_STACK="no"
ENABLE_AI_RUNTIME="no"
ALLOW_HTTP="no"
ALLOW_HTTPS="no"
TLS_MODE="off"
POST_INSTALL_REBOOT="no"
