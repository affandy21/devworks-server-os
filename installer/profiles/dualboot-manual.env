# Devworks Server OS dual boot profile.
# Prepare unallocated space in Windows Disk Management first, create a Linux
# root partition from the live session, then fill the partition paths below.
# This profile never resizes Windows and refuses to format the EFI partition.
DEVWORKS_I_UNDERSTAND_THIS_ERASES_DISK="no"
DEVWORKS_MANUAL_CONFIRM_DISK="yes"
DEVWORKS_ALLOW_INSTALL_ON_MOUNTED_DISK="no"
INSTALL_MODE="manual-partition"
TARGET_DISK="auto"
TARGET_BOOT_MODE="efi"
TARGET_ROOT_PARTITION=""         # required, example: /dev/nvme0n1p6
TARGET_EFI_PARTITION=""          # required existing ESP, example: /dev/nvme0n1p1
TARGET_SWAP_PARTITION=""         # optional prepared swap partition
FORMAT_ROOT="yes"
FORMAT_EFI="no"
FORMAT_SWAP="yes"
TARGET_ROOT_LABEL="DEVWORKS_ROOT"
TARGET_SWAP_LABEL="DWORKS_SWAP"

DEVWORKS_HOSTNAME="devworks-server"
DEVWORKS_VERSION="0.2.1"
DEVWORKS_VERSION_NAME="Dual Boot Hardware"
TIMEZONE="Asia/Jakarta"
LOCALE="en_US.UTF-8"
KEYMAP="us"
APT_COMPONENTS="main contrib non-free non-free-firmware"
ENABLE_HARDWARE_BACKPORTS="no"

ADMIN_USER="devworks"
ADMIN_FULL_NAME="Devworks Administrator"
ADMIN_PASSWORD_MODE="prompt"
ADMIN_PASSWORD_HASH=""
FORCE_PASSWORD_CHANGE="no"
ADMIN_SUDO_NOPASSWD="no"
ENABLE_AUTOLOGIN="no"

SSH_PORT="22"
SSH_PASSWORD_AUTH="yes"
SSH_PERMIT_ROOT_LOGIN="no"
SSH_ALLOW_USERS="${ADMIN_USER}"
SSH_AUTHORIZED_KEYS_FILE=""
SSH_KEY_SETUP_MODE="prompt"
REQUIRE_SSH_AUTHORIZED_KEYS="no"
SSH_DISABLE_EMPTY_PASSWORDS="yes"
SSH_MAX_AUTH_TRIES="3"

ENABLE_UFW="yes"
ALLOW_HTTP="no"
ALLOW_HTTPS="no"
ALLOW_ADMIN_UI_PORT="no"
TLS_MODE="off"

ENABLE_WEB_STACK="no"
ENABLE_AI_RUNTIME="no"
ENABLE_CONTAINER_RUNTIME="none"
INSTALL_WEB_FEATURE_PACKAGES="yes"
INSTALL_AI_FEATURE_PACKAGES="no"
INSTALL_CONTAINER_FEATURE_PACKAGES="no"
ENABLE_SERVICE_WIZARD="yes"

ENABLE_GUI="yes"
ENABLE_NATIVE_MONITOR="yes"
ENABLE_ADMIN_WEB_UI="no"
ADMIN_WEB_UI_BIND="127.0.0.1"

ENABLE_UNATTENDED_UPGRADES="yes"
ENABLE_AUTO_REBOOT_AFTER_SECURITY_UPDATE="no"
GRUB_TIMEOUT="8"
ENABLE_GRUB_RECOVERY="yes"
ENABLE_WINDOWS_BOOT_DETECTION="yes"
POST_INSTALL_REBOOT="no"
