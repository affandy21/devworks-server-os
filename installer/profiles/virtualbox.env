# VirtualBox lab profile. Import this after config.env or use it directly.
DEVWORKS_I_UNDERSTAND_THIS_ERASES_DISK="no"
DEVWORKS_MANUAL_CONFIRM_DISK="yes"
DEVWORKS_ALLOW_INSTALL_ON_MOUNTED_DISK="no"
INSTALL_MODE="erase-disk"
TARGET_DISK="auto"
TARGET_BOOT_MODE="auto"
TARGET_SWAP_SIZE_MIB="2048"
DEVWORKS_HOSTNAME="devworks-server"
ADMIN_USER="devworks"
ENABLE_AUTOLOGIN="yes"
SSH_PASSWORD_AUTH="yes"
ENABLE_GUI="yes"
ENABLE_NATIVE_MONITOR="yes"
ENABLE_ADMIN_WEB_UI="yes"
ALLOW_ADMIN_UI_PORT="yes"
ENABLE_CONTAINER_RUNTIME="podman"
TLS_MODE="self-signed"
POST_INSTALL_REBOOT="no"
