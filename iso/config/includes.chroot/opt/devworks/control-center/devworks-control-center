SERVICES = ("ssh", "nginx", "podman", "docker", "fail2ban", "chrony", "devworks-admin-ui")
HISTORY = 90
TICK_MS = 1000
APP_ICON = "/opt/devworks/control-center/devworks-control-center.png"
SPARK_CHARS = "▁▂▃▄▅▆▇█"


def read_first_line(path, default=""):
    try:
        with open(path, "r", encoding="utf-8") as handle:
            return handle.readline().strip()
    except OSError:
        return default


def read_cpu_sample():
    line = read_first_line("/proc/stat")
    if not line.startswith("cpu "):
        return None
    parts = [int(value) for value in line.split()[1:8]]
    idle = parts[3] + parts[4]
    total = sum(parts)
    return idle, total


def cpu_percent(previous, current):
    if not previous or not current:
        return 0.0
    idle_delta = current[0] - previous[0]
    total_delta = current[1] - previous[1]
    if total_delta <= 0:
        return 0.0
    return max(0.0, min(100.0, 100.0 * (1.0 - idle_delta / total_delta)))


def read_meminfo():
    values = {}
    try:
        with open("/proc/meminfo", "r", encoding="utf-8") as handle:
            for line in handle:
                key, raw = line.split(":", 1)
                values[key] = int(raw.strip().split()[0]) * 1024
    except OSError:
        pass
    total = values.get("MemTotal", 0)
    available = values.get("MemAvailable", 0)
    used = max(0, total - available)
    percent = (used / total) * 100.0 if total else 0.0
    return total, used, available, percent


def read_network_bytes():
    rx_total = 0
    tx_total = 0
    try:
        with open("/proc/net/dev", "r", encoding="utf-8") as handle:
            for line in handle.readlines()[2:]:
                name, data = line.split(":", 1)
                if name.strip() == "lo":
                    continue
                fields = data.split()
                rx_total += int(fields[0])
                tx_total += int(fields[8])
    except OSError:
        pass
    return rx_total, tx_total


def disk_percent():
    usage = shutil.disk_usage("/")
    return usage.total, usage.used, usage.free, (usage.used / usage.total) * 100.0


def service_state(name):
    try:
        result = subprocess.run(
            ["systemctl", "is-active", name],
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            timeout=1.5,
            check=False,
        )
        return (result.stdout.strip() or "unknown").lower()
    except (OSError, subprocess.TimeoutExpired):
        return "unavailable"


def fmt_bytes(value):
    units = ("B", "KB", "MB", "GB", "TB")
    number = float(value)
    for unit in units:
        if number < 1024.0 or unit == units[-1]:
            return f"{number:.1f} {unit}" if unit != "B" else f"{int(number)} B"
        number /= 1024.0
    return f"{number:.1f} TB"


def fmt_rate(value):
    return f"{fmt_bytes(max(0, value))}/s"


class MetricGraph(Gtk.DrawingArea):
    def __init__(self, color):
        super().__init__()
        self.color = color
        self.values = deque([0.0] * HISTORY, maxlen=HISTORY)
        self.set_size_request(280, 126)
        self.set_hexpand(True)
        self.set_vexpand(True)
        self.connect("draw", self.on_draw)

    def push(self, value):
        self.values.append(max(0.0, min(100.0, float(value))))
        self.queue_draw()

    def on_draw(self, _widget, cr):
        width = self.get_allocated_width()
        height = self.get_allocated_height()
        red, green, blue = self.color
        radius = 7
        cr.new_sub_path()
        cr.arc(width - radius, radius, radius, -1.5708, 0)
        cr.arc(width - radius, height - radius, radius, 0, 1.5708)
        cr.arc(radius, height - radius, radius, 1.5708, 3.1416)
        cr.arc(radius, radius, radius, 3.1416, 4.7124)
        cr.close_path()
        cr.set_source_rgba(0.03, 0.11, 0.20, 1.0)
        cr.fill_preserve()
        cr.set_line_width(1)
        cr.set_source_rgba(red, green, blue, 0.35)
        cr.stroke()

        inset = 8
        chart_x = inset
        chart_y = inset
        chart_w = max(1, width - inset * 2)
        chart_h = max(1, height - inset * 2)

        cr.set_line_width(1)
        cr.set_source_rgba(red, green, blue, 0.22)
        for idx in range(1, 4):
            y = chart_y + chart_h * idx / 4
            cr.move_to(chart_x, y)
            cr.line_to(chart_x + chart_w, y)
        for idx in range(1, 9):
            x = chart_x + chart_w * idx / 9
            cr.move_to(x, chart_y)
            cr.line_to(x, chart_y + chart_h)
        cr.stroke()

        cr.set_line_width(1.4)
        cr.set_source_rgba(red, green, blue, 0.42)
        cr.move_to(chart_x, chart_y + chart_h)
        cr.line_to(chart_x + chart_w, chart_y + chart_h)
        cr.stroke()

        cr.set_source_rgba(0.75, 0.92, 1.0, 0.35)
        cr.select_font_face("DejaVu Sans", 0, 0)
        cr.set_font_size(9)
        cr.move_to(chart_x + 2, chart_y + 10)
        cr.show_text("100")
        cr.move_to(chart_x + 2, chart_y + chart_h - 4)
        cr.show_text("0")

        points = list(self.values)
        if len(points) < 2:
            return False
        step = chart_w / (len(points) - 1)
        coords = []
        for idx, value in enumerate(points):
            x = chart_x + idx * step
            visible_value = max(value, 5.0 if value > 0 else 1.0)
            y = chart_y + chart_h - ((visible_value / 100.0) * chart_h)
            coords.append((x, y))

        cr.move_to(coords[0][0], chart_y + chart_h)
        for x, y in coords:
            cr.line_to(x, y)
        cr.line_to(coords[-1][0], chart_y + chart_h)
        cr.close_path()
        cr.set_source_rgba(red, green, blue, 0.30)
        cr.fill()

        cr.set_line_width(6.0)
        cr.set_source_rgba(red, green, blue, 0.20)
        cr.move_to(*coords[0])
        for x, y in coords[1:]:
            cr.line_to(x, y)
        cr.stroke()

        cr.set_line_width(3.0)
        cr.set_source_rgba(red, green, blue, 0.98)
        cr.move_to(*coords[0])
        for x, y in coords[1:]:
            cr.line_to(x, y)
        cr.stroke()

        last_x, last_y = coords[-1]
        cr.arc(last_x, last_y, 4.5, 0, 6.283)
        cr.set_source_rgba(0.88, 1.0, 1.0, 0.98)
        cr.fill_preserve()
        cr.set_line_width(2)
        cr.set_source_rgba(red, green, blue, 0.98)
        cr.stroke()
        return False


class MetricPanel(Gtk.Box):
    def __init__(self, title, color):
        super().__init__(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        self.get_style_context().add_class("panel")
        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        self.title = Gtk.Label(label=title, xalign=0)
        self.title.get_style_context().add_class("panel-title")
        self.value = Gtk.Label(label="0%", xalign=1)
        self.value.get_style_context().add_class("metric-value")
        header.pack_start(self.title, True, True, 0)
        header.pack_end(self.value, False, False, 0)
        self.values = deque([0.0] * 28, maxlen=28)
        self.color = "#{:02x}{:02x}{:02x}".format(
            int(color[0] * 255),
            int(color[1] * 255),
            int(color[2] * 255),
        )
        self.spark = Gtk.Label(xalign=0)
        self.spark.set_hexpand(False)
        self.spark.get_style_context().add_class("sparkline")
        self.detail = Gtk.Label(label="", xalign=0)
        self.detail.get_style_context().add_class("muted")
        self.pack_start(header, False, False, 0)
        self.pack_start(self.spark, True, True, 0)
        self.pack_start(self.detail, False, False, 0)

    def update(self, percent, detail):
        self.value.set_text(f"{percent:.0f}%")
        self.detail.set_text(detail)
        self.values.append(max(0.0, min(100.0, float(percent))))
        chars = []
        for value in self.values:
            if value <= 0:
                chars.append(SPARK_CHARS[0])
            else:
                index = max(1, min(len(SPARK_CHARS) - 1, int((value / 100.0) * (len(SPARK_CHARS) - 1))))
                chars.append(SPARK_CHARS[index])
        self.spark.set_markup(
            f'<span foreground="{escape(self.color)}" font_family="monospace" font_size="17408">'
            f'{escape("".join(chars))}</span>'
        )


class DevworksControlCenter(Gtk.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app, title="Devworks Control Center")
        screen = Gdk.Screen.get_default()
        max_width = screen.get_width() - 48 if screen else 960
        max_height = screen.get_height() - 88 if screen else 640
        self.set_default_size(max(780, min(960, max_width)), max(540, min(660, max_height)))
        if os.path.exists(APP_ICON):
            self.set_icon_from_file(APP_ICON)
        else:
            self.set_icon_name("devworks-control-center")
        self.prev_cpu = read_cpu_sample()
        self.prev_net = read_network_bytes()
        self.prev_net_time = time.monotonic()

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        root.get_style_context().add_class("app")
        self.add(root)

        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=14)
        header.get_style_context().add_class("header")
        if os.path.exists(APP_ICON):
            logo = Gtk.Image.new_from_pixbuf(
                GdkPixbuf.Pixbuf.new_from_file_at_scale(APP_ICON, 44, 44, True)
            )
        else:
            logo = Gtk.Image.new_from_icon_name("devworks-control-center", Gtk.IconSize.DIALOG)
        title_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        title = Gtk.Label(label="Devworks Control Center", xalign=0)
        title.get_style_context().add_class("title")
        self.subtitle = Gtk.Label(label="Kernel realtime monitor", xalign=0)
        self.subtitle.get_style_context().add_class("muted")
        title_box.pack_start(title, False, False, 0)
        title_box.pack_start(self.subtitle, False, False, 0)
        self.clock = Gtk.Label(label="", xalign=1)
        self.clock.get_style_context().add_class("clock")
        header.pack_start(logo, False, False, 0)
        header.pack_start(title_box, True, True, 0)
        header.pack_end(self.clock, False, False, 0)
        root.pack_start(header, False, False, 0)

        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        root.pack_start(scroller, True, True, 0)

        body = Gtk.Grid()
        body.set_column_spacing(12)
        body.set_row_spacing(12)
        body.set_margin_top(12)
        body.set_margin_bottom(12)
        body.set_margin_start(12)
        body.set_margin_end(12)
        scroller.add(body)

        self.cpu_panel = MetricPanel("CPU", (0.23, 0.84, 0.96))
        self.mem_panel = MetricPanel("Memory", (0.56, 0.45, 1.00))
        self.disk_panel = MetricPanel("Disk", (0.22, 0.95, 0.65))
        self.net_panel = MetricPanel("Network", (1.00, 0.36, 0.48))
        body.attach(self.cpu_panel, 0, 0, 1, 1)
        body.attach(self.mem_panel, 1, 0, 1, 1)
        body.attach(self.disk_panel, 0, 1, 1, 1)
        body.attach(self.net_panel, 1, 1, 1, 1)

        side = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        body.attach(side, 0, 2, 2, 1)

        self.system_box = self.make_info_panel("System")
        self.services_box = self.make_info_panel("Services")
        side.pack_start(self.system_box, True, True, 0)
        side.pack_start(self.services_box, True, True, 0)

        self.apply_css()
        self.refresh()
        GLib.timeout_add(TICK_MS, self.refresh)

    def make_info_panel(self, title):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.get_style_context().add_class("panel")
        label = Gtk.Label(label=title, xalign=0)
        label.get_style_context().add_class("panel-title")
        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=7)
        box.pack_start(label, False, False, 0)
        box.pack_start(content, True, True, 0)
        box.content = content
        return box

    def set_rows(self, panel, rows):
        for child in panel.content.get_children():
            panel.content.remove(child)
        for left, right, state in rows:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            row.get_style_context().add_class("row")
            dot = Gtk.Label(label="o")
            dot.get_style_context().add_class("dot")
            dot.get_style_context().add_class(state)
            key = Gtk.Label(label=left, xalign=0)
            key.get_style_context().add_class("muted")
            value = Gtk.Label(label=right, xalign=1)
            value.get_style_context().add_class("row-value")
            row.pack_start(dot, False, False, 0)
            row.pack_start(key, True, True, 0)
            row.pack_end(value, False, False, 0)
            panel.content.pack_start(row, False, False, 0)
        panel.show_all()

    def refresh(self):
        now_cpu = read_cpu_sample()
        cpu = cpu_percent(self.prev_cpu, now_cpu)
        self.prev_cpu = now_cpu
        load = os.getloadavg()[0] if hasattr(os, "getloadavg") else 0.0
        cores = os.cpu_count() or 1
        self.cpu_panel.update(cpu, f"{cores} cores   load {load:.2f}")

        mem_total, mem_used, mem_avail, mem_pct = read_meminfo()
        self.mem_panel.update(mem_pct, f"{fmt_bytes(mem_used)} used   {fmt_bytes(mem_avail)} free")

        disk_total, disk_used, disk_free, disk_pct = disk_percent()
        self.disk_panel.update(disk_pct, f"{fmt_bytes(disk_used)} used   {fmt_bytes(disk_free)} free")

        rx, tx = read_network_bytes()
        now = time.monotonic()
        elapsed = max(0.001, now - self.prev_net_time)
        rx_rate = (rx - self.prev_net[0]) / elapsed
        tx_rate = (tx - self.prev_net[1]) / elapsed
        self.prev_net = (rx, tx)
        self.prev_net_time = now
        net_pct = min(100.0, ((rx_rate + tx_rate) / (1024 * 1024 * 12)) * 100.0)
        self.net_panel.update(net_pct, f"down {fmt_rate(rx_rate)}   up {fmt_rate(tx_rate)}")

        uptime = float(read_first_line("/proc/uptime", "0").split()[0])
        self.subtitle.set_text(f"{platform.node() or 'devworks-server'}   Linux {platform.release()}   uptime {int(uptime // 3600)}h {int((uptime % 3600) // 60)}m")
        self.clock.set_text(time.strftime("%Y-%m-%d  %H:%M:%S"))
        self.set_rows(self.system_box, [
            ("OS", "Devworks Server OS", "ok"),
            ("Kernel", platform.release(), "ok"),
            ("Root disk", f"{fmt_bytes(disk_total)} total", "ok"),
        ])
        service_rows = []
        for name in SERVICES:
            state = service_state(name)
            css = "ok" if state == "active" else "warn" if state in ("inactive", "activating") else "bad"
            service_rows.append((name, state, css))
        self.set_rows(self.services_box, service_rows)
        return True

    def apply_css(self):
        css = b"""
        window { background: #07111f; color: #e9f3ff; font-family: DejaVu Sans, sans-serif; }
        .app { background: #07111f; }
        .header { background: #0b1728; border-bottom: 1px solid rgba(93, 175, 221, 0.24); padding: 12px 16px; }
        .title { font-size: 22px; font-weight: 700; color: #ffffff; }
        .clock { color: #8fb7d5; font-size: 13px; }
        .panel { background: #0c1a2e; border: 1px solid rgba(91, 185, 230, 0.22); border-radius: 8px; padding: 12px; }
        .panel-title { color: #ffffff; font-weight: 700; font-size: 14px; }
        .metric-value { color: #7ff4ff; font-size: 24px; font-weight: 700; }
        .sparkline { padding: 18px 0 12px 0; letter-spacing: 0; }
        .muted { color: #91a9bf; font-size: 12px; }
        .row { padding: 3px 0; }
        .row-value { color: #dcecff; font-weight: 600; }
        .dot { font-size: 13px; }
        .ok { color: #2df49a; }
        .warn { color: #ffd166; }
        .bad { color: #ff5a7a; }
        """
        provider = Gtk.CssProvider()
        provider.load_from_data(css)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(),
            provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )


class DevworksApp(Gtk.Application):
    def __init__(self):
        super().__init__(application_id="id.devworks.ControlCenter")

    def do_activate(self):
        window = self.props.active_window
        if not window:
            window = DevworksControlCenter(self)
            window.show_all()
        window.present()


if __name__ == "__main__":
    raise SystemExit(DevworksApp().run(sys.argv))
